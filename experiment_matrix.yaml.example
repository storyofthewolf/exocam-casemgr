# ExoCAM experiment matrix — annotated example
# Copy this file, rename it (e.g. my_co2_sweep.yaml), fill in values, then:
#   python exo_build.py my_co2_sweep.yaml --outdir scripts/
#
# The tool generates one shell script per case, plus a staged exoplanet_mod.F90.
# Review scripts before running. Submission (.run) is always manual.

meta:
  description: CO2 partial pressure sweep, aquaplanet FV, n68equiv RT
  author: E.T. Wolf
  created: 2026-05-02

# Path to the config_registry.yaml for this machine
config_registry: /path/to/ExoCAM/tools/case_mgmt/config_registry.yaml

# Optional: override machine paths from config_registry.yaml
# paths:
#   caseroot: /my/scratch/cases
#   cesm_scripts: /my/cesm/scripts

base:

  # -----------------------------------------------------------------------
  # CESM configuration
  # -----------------------------------------------------------------------
  config_type:  cam_aqua_fv   # cam_aqua_fv | cam_land_fv | cam_mixed_fv
                               # cam_aqua_se_ne5 | cam_aqua_se_ne16
  exort_pkg:    n68equiv       # n68equiv | n84equiv | n28archean | n42h2o
  cloud_scheme: rk             # rk (CAM4 default) | mg (Morrison-Gettelman)
  nlev:         40             # must match L<N> in IC filename and -nlev in CAM_CONFIG_OPTS
  mach:         discover       # CESM machine name

  # Clone mode — uncomment to build all cases via create_clone from a single source.
  # config_type, exort_pkg, nlev are optional; include them to enable IC file lookup
  # and CAM_CONFIG_OPTS update; omit to inherit everything from the source case.
  # clone: my_completed_base_case

  # Run length (xmlchange)
  stop_option:  nyears
  stop_n:       20
  rest_n:       5

  # Processor counts
  ntasks:   126            # Milan chips on discover

  # HPC batch options (written to ${CASE}.run after cesm_setup)
  account:  s2427          # SLURM charge account (#SBATCH --account)

  # -----------------------------------------------------------------------
  # Atmospheric composition  (all in bar)
  # N2 is computed as 1 - sum(others) for 1-bar atmospheres.
  # Set exo_n2bar_explicit for non-1-bar total pressures.
  # -----------------------------------------------------------------------
  exo_co2bar:   0.0004
  exo_ch4bar:   1.7e-6
  exo_c2h6bar:  0.0
  exo_nh3bar:   0.0
  exo_cobar:    0.0
  exo_h2bar:    0.0
  exo_o2bar:    0.2095
  # exo_n2bar_explicit: 0.79   # uncomment to set N2 directly (required for non-1-bar atmospheres)

  # -----------------------------------------------------------------------
  # Stellar forcing
  # Default solar file constructed from registry: {exort_root}/ExoRT/data/solar/G2V_SUN_n68.nc
  # Override here only if using a non-standard stellar SED.
  # -----------------------------------------------------------------------
  exo_scon:     1360.0         # stellar constant (W/m^2)
  # exo_solar_file: /discover/nobackup/etwolf/models/ExoRT/data/solar/BT_Settl_3400K_n68.nc

  # -----------------------------------------------------------------------
  # Geophysical parameters
  # -----------------------------------------------------------------------
  exo_surface_gravity: 9.81       # m/s^2
  exo_planet_radius:   6.37122e6  # m
  exo_ndays:           1.0        # diurnal period (Earth days)
  exo_porb:            365.0      # orbital period (Earth days)
  exo_sday:            86164.0    # sidereal day (s); Earth = 86164.0
                                  # synchronous: 86400 * exo_ndays
                                  # async slow: 86400 * ndays / (1 + ndays/porb)
  exo_eccen:           0.0
  exo_obliq:           0.0

  # -----------------------------------------------------------------------
  # Model options (run flags)
  # -----------------------------------------------------------------------
  do_exo_atmconst:    true    # read gas constituents from this file; overrides ghg namelist
  do_exo_rt:          true    # use correlated-k ExoRT radiation
  do_exo_synchronous: false   # synchronous rotation mode
  do_exo_gw:          false   # gravity wave parameterization (avoid for low-P atmospheres)
  do_exo_simplevolc:  false   # simple volcanic forcing

  # -----------------------------------------------------------------------
  # Radiation options
  # -----------------------------------------------------------------------
  exo_convect_plim:    4.0e3  # min convection pressure (Pa); 5 without ozone, 4e3 with ozone
  exo_rad_step:        3      # radiation calc frequency (timesteps > 0, or hours < 0)
  do_exo_rt_clearsky:  false  # parallel clear-sky calculation (slow, use sparingly)
  do_exo_rt_spectral:  false  # output spectrally resolved radiative fluxes
  do_exo_rt_carma:     false  # link CARMA aerosol absorption to ExoRT (requires CARMA build)

  # -----------------------------------------------------------------------
  # Ocean/SOM forcing file (cam_aqua_fv, cam_aqua_se_*, cam_mixed_fv only)
  # Absolute path to the pop_frc* file used in user_docn.streams.txt.som.
  # -----------------------------------------------------------------------
  # som_pop_frc_file: /discover/nobackup/etwolf/exofiles/cam4_fv_4x5_aquaplanet/pop_frc.4x5d.090130_aquaplanet_Earth.nc

  # -----------------------------------------------------------------------
  # CLM land surface files (cam_land_fv, cam_mixed_fv only)
  # Absolute paths, or filenames relative to {exocam_root}/cesm1.2.1/initial_files/cam_land_fv/
  # -----------------------------------------------------------------------
  # finidat: landplanet_dry.clm2.r.nc
  # fsurdat: surfdata_4x5_sand_fmax0.5_sc21.nc

  # -----------------------------------------------------------------------
  # CARMA aerosol parameters (only needed if do_exo_rt_carma: true)
  # Added to user_nl_cam via echo >> at build time.
  # -----------------------------------------------------------------------
  # carma_params:
  #   carma_do_fixedinit:  .false.
  #   carma_do_substep:    .false.
  #   carma_do_coag:       .false.
  #   carma_volc_reff:     '0.5'
  #   carma_emis_file:     '"/discover/nobackup/etwolf/models/ExoCAM/cesm1.2.1/initial_files/carma/hazyCHAMPS_case23_hazeprod_zen.nc"'
  #   carma_escale_file:   '" "'
  #   carma_emis_total:    1.0e5

  # -----------------------------------------------------------------------
  # Volcanic forcing parameters (only needed if do_exo_simplevolc: true)
  # Added to user_nl_cam via echo >> at build time.
  # -----------------------------------------------------------------------
  # volc_params:
  #   volc_emis_so2_total: 6.0e10
  #   volc_emis_h2o_total: 1.0e9
  #   volc_duration:       '24.0'
  #   volc_press:          '10.0'
  #   volc_press_sigma:    '0.3'
  #   volc_weight_floor:   '1.0e-4'
  #   volc_lon:            '30.0'
  #   volc_lat:            '2.0'
  #   volc_so2_lifetime:   '35.0'

cases:
  # Minimal case — inherits all base values
  # job_name sets #SBATCH -J (short queue label); omit to skip that line
  - name: co2_modern
    exo_co2bar: 0.0004
    job_name:   co2mod

  # Clone example — create_clone copies SourceMods/namelists from an existing case.
  # Typically clone belongs in base so all cases share the same source.
  # config_type, exort_pkg, nlev are optional (inherited from clone source);
  # supply them only if you want the IC file lookup and CAM_CONFIG_OPTS update.
  # Per-case clone is supported but unusual — use it only when cases clone
  # from different sources.
  - name: co2_modern_2x_scon
    exo_scon:   2720.0

  - name: co2_1x
    exo_co2bar: 0.001

  - name: co2_10x
    exo_co2bar: 0.004

  - name: co2_100x
    exo_co2bar: 0.04

  # High-pressure 10-bar N2/CO2 atmosphere — must use matching IC file
  - name: co2_10bar_n2
    exo_co2bar:          1.0
    exo_o2bar:           0.0
    exo_n2bar_explicit:  9.0          # N2 = 9 bar; total = 10 bar
    nlev:                51           # must match IC file for 10bar/L51
    # ntasks:          512

  # H2-dominated world, synchronous rotator
  - name: h2_sync_1360
    exo_h2bar:           0.9
    exo_co2bar:          0.001
    exo_o2bar:           0.0
    exo_ch4bar:          0.0
    exo_n2bar_explicit:  0.099        # total = 1.0 bar
    exo_scon:            900.0
    do_exo_synchronous:  true
    exo_ndays:           10.0
    exo_sday:            864000.0     # = 86400 * exo_ndays (synchronous)
    exo_porb:            10.0
    exo_convect_plim:    5.0          # no ozone

  # M-dwarf target, different stellar SED
  - name: k2_18b_analog
    exo_scon:            1000.0
    exo_surface_gravity: 12.4
    exo_planet_radius:   1.448e7      # 2.27 Earth radii
    exo_solar_file: /discover/nobackup/etwolf/models/ExoRT/data/solar/K2V_n68.nc
    exo_co2bar:          0.01
    exo_h2bar:           0.8
    exo_n2bar_explicit:  0.19
    exo_o2bar:           0.0
    nlev:                51
    ncdata_override: ic_1bar_L51_zmean_ic.nc

  # Land planet example (cam_land_fv config)
  - name: land_modern_earth
    config_type:  cam_land_fv
    finidat: landplanet_dry.clm2.r.nc
    fsurdat: surfdata_4x5_sand_fmax0.5_sc21.nc

  # Hazy Archean with CARMA aerosols
  - name: archean_hazy_carma
    exort_pkg:           n28archean
    exo_ch4bar:          0.01
    exo_co2bar:          0.02
    exo_o2bar:           0.0
    do_exo_rt_carma:     true
    som_pop_frc_file: /discover/nobackup/etwolf/exofiles/cam4_fv_4x5_aquaplanet/pop_frc.4x5d.090130_aquaplanet_Earth.nc
    carma_params:
      carma_do_fixedinit:  .false.
      carma_do_substep:    .false.
      carma_do_coag:       .false.
      carma_volc_reff:     '0.5'
      carma_emis_file:     '"/discover/nobackup/etwolf/models/ExoCAM/cesm1.2.1/initial_files/carma/hazyCHAMPS_case23_hazeprod_zen.nc"'
      carma_escale_file:   '" "'
      carma_emis_total:    1.0e5

  # Volcanic world
  - name: volc_modern
    do_exo_simplevolc: true
    volc_params:
      volc_emis_so2_total: 6.0e10
      volc_emis_h2o_total: 1.0e9
      volc_duration:       '24.0'
      volc_press:          '10.0'
      volc_press_sigma:    '0.3'
      volc_weight_floor:   '1.0e-4'
      volc_lon:            '30.0'
      volc_lat:            '2.0'
      volc_so2_lifetime:   '35.0'
